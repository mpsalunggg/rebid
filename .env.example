PORT=8080
HOST=localhost

DB_HOST=localhost
DB_PORT=5432
DB_USER=rebid_user
DB_PASSWORD=rebid_password
DB_NAME=rebid_db
DB_SSLMODE=disable

JWT_SECRET=your-secret-key-here

# Auction closer worker — 6-field cron with seconds (github.com/robfig/cron/v3 WithSeconds)
# Examples:
#   */30 * * * * *   every 30 seconds (default)
#   0 * * * * *      every minute at second 0
#   0 */5 * * * *    every 5 minutes
AUCTION_CLOSER_CRON=*/30 * * * * *